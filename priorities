<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0d0d0d">
<title>Studio Strong — My Priorities</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --teal: #2b7d94;
    --teal-light: #3a9ab5;
    --teal-dim: rgba(43,125,148,0.15);
    --teal-glow: rgba(43,125,148,0.3);
    --black: #0d0d0d;
    --surface: #141414;
    --surface2: #1c1c1c;
    --surface3: #242424;
    --border: rgba(255,255,255,0.06);
    --text: #e8e8e8;
    --text-dim: #888;
    --text-faint: #555;
    --april: #e8845a;
    --may: #e8c45a;
    --june: #7ec87e;
    --other: #9b8fc4;
    --personal: #c47eb0;
    --radius: 10px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--black); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; }
  body::before {
    content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
    background-image: linear-gradient(rgba(43,125,148,0.03) 1px,transparent 1px), linear-gradient(90deg,rgba(43,125,148,0.03) 1px,transparent 1px);
    background-size:40px 40px;
  }
  .wrapper { position:relative; z-index:1; max-width:800px; margin:0 auto; padding:0 20px 60px; }

  header {
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 0 16px; border-bottom:1px solid var(--border); margin-bottom:24px;
    position:sticky; top:0; background:rgba(13,13,13,0.95); backdrop-filter:blur(10px); z-index:100;
  }
  .logo { display:flex; align-items:center; gap:10px; }
  .logo-mark {
    width:32px; height:32px; background:var(--teal); border-radius:7px;
    display:flex; align-items:center; justify-content:center;
    font-family:'DM Serif Display',serif; font-size:16px; font-style:italic; color:white;
  }
  .logo-text strong { font-size:13px; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:var(--text); display:block; line-height:1.1; }
  .logo-text span { font-size:11px; color:var(--text-dim); font-weight:300; }
  .header-right { display:flex; align-items:center; gap:12px; }
  .refresh-info { font-size:11px; color:var(--text-faint); font-family:'DM Mono',monospace; }
  .live-dot { display:inline-block; width:6px; height:6px; background:var(--teal); border-radius:50%; margin-right:5px; animation:livepulse 2s infinite; }
  @keyframes livepulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  #refresh-btn {
    background:var(--teal-dim); border:1px solid var(--teal-glow); color:var(--teal-light);
    font-family:'DM Sans',sans-serif; font-size:12px; font-weight:500; padding:6px 14px;
    border-radius:6px; cursor:pointer; transition:all .2s;
  }
  #refresh-btn:hover { background:var(--teal-glow); }
  #refresh-btn:active { transform:scale(.97); }
  #refresh-btn.spinning { opacity:.5; pointer-events:none; }

  /* No key error */
  #no-key {
    max-width:420px; margin:80px auto; padding:36px;
    background:var(--surface); border:1px solid var(--border); border-radius:16px; text-align:center;
  }
  #no-key .icon { font-size:32px; margin-bottom:14px; }
  #no-key h2 { font-family:'DM Serif Display',serif; font-size:20px; margin-bottom:10px; }
  #no-key p { font-size:13px; color:var(--text-dim); line-height:1.7; }
  #no-key code { font-family:'DM Mono',monospace; font-size:12px; background:var(--surface2); padding:2px 6px; border-radius:4px; color:var(--teal-light); }

  /* Owner banner */
  .owner-banner { display:flex; align-items:center; gap:12px; margin-bottom:20px; }
  .avatar { width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:15px; font-weight:600; flex-shrink:0; }
  .owner-name { font-family:'DM Serif Display',serif; font-size:22px; font-style:italic; }
  .owner-sub { font-size:12px; color:var(--text-faint); }

  /* Stats */
  .stats-row { display:flex; gap:10px; margin-bottom:24px; flex-wrap:wrap; }
  .stat-chip { background:var(--surface2); border:1px solid var(--border); border-radius:7px; padding:8px 14px; font-size:12px; color:var(--text-dim); }
  .stat-chip strong { display:block; font-size:20px; font-family:'DM Mono',monospace; color:var(--text); line-height:1.2; }

  /* Tabs */
  .section-tabs { display:flex; gap:4px; margin-bottom:20px; background:var(--surface2); border-radius:8px; padding:3px; max-width:280px; }
  .tab-btn { flex:1; padding:7px 12px; background:transparent; border:none; border-radius:6px; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:500; color:var(--text-dim); cursor:pointer; transition:all .15s; }
  .tab-btn.active { background:var(--surface3); color:var(--text); }

  /* Month groups */
  .month-group { margin-bottom:28px; }
  .month-label { display:flex; align-items:center; gap:8px; margin-bottom:10px; }
  .month-pill { font-size:10px; font-weight:600; letter-spacing:.1em; text-transform:uppercase; padding:3px 10px; border-radius:4px; }
  .month-april  { background:rgba(232,132,90,.15); color:var(--april); }
  .month-may    { background:rgba(232,196,90,.12); color:var(--may); }
  .month-june   { background:rgba(126,200,126,.12); color:var(--june); }
  .month-other  { background:rgba(155,143,196,.12); color:var(--other); }
  .month-nodate { background:rgba(255,255,255,.04); color:var(--text-faint); }
  .month-count  { font-size:11px; color:var(--text-faint); }

  /* Task cards */
  .task-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:13px 15px; margin-bottom:7px; transition:border-color .15s, background .15s; }
  .task-card:hover { border-color:rgba(255,255,255,.1); background:var(--surface2); }
  .task-content { font-size:13px; line-height:1.55; color:var(--text); margin-bottom:7px; }
  .task-meta { display:flex; align-items:center; gap:5px; flex-wrap:wrap; }
  .tag { font-size:10px; font-weight:500; padding:2px 7px; border-radius:3px; letter-spacing:.03em; }
  .tag-personal { background:rgba(196,126,176,.12); color:var(--personal); }
  .tag-business { background:var(--teal-dim); color:var(--teal-light); }
  .tag-topic    { background:rgba(255,255,255,.05); color:var(--text-faint); }
  .task-people  { font-size:11px; color:var(--text-dim); margin-left:auto; }

  .state-msg { text-align:center; padding:48px 20px; color:var(--text-faint); font-size:13px; line-height:1.9; }
  .state-msg .icon { font-size:30px; display:block; margin-bottom:10px; }
  .error-bar { background:rgba(200,80,80,.1); border:1px solid rgba(200,80,80,.2); color:#e08080; font-size:12px; padding:8px 14px; border-radius:6px; margin-bottom:14px; }
  .fetched-time { font-family:'DM Mono',monospace; font-size:10px; color:var(--text-faint); text-align:right; margin-bottom:8px; }
</style>
</head>
<body>
<div class="wrapper">

<header>
  <div class="logo">
    <div class="logo-mark">S</div>
    <div class="logo-text">
      <strong>Studio Strong</strong>
      <span id="header-sub">My Priorities</span>
    </div>
  </div>
  <div class="header-right">
    <span class="refresh-info"><span class="live-dot"></span><span id="last-refresh">—</span></span>
    <button id="refresh-btn" onclick="load()">↻ Refresh</button>
  </div>
</header>

<!-- No key state -->
<div id="no-key" style="display:none">
  <div class="icon">🔑</div>
  <h2>Missing Access Key</h2>
  <p>Add your key to the URL:<br><br><code>?key=YOUR_KEY_HERE</code></p>
</div>

<!-- Dashboard -->
<div id="dashboard" style="display:none">
  <div class="owner-banner">
    <div class="avatar" id="owner-avatar"></div>
    <div>
      <div class="owner-name" id="owner-name">—</div>
      <div class="owner-sub">Studio Strong</div>
    </div>
  </div>

  <div class="stats-row" id="stats-row"></div>

  <div class="section-tabs">
    <button class="tab-btn active" onclick="switchTab('all',this)">All</button>
    <button class="tab-btn" onclick="switchTab('business',this)">Business</button>
    <button class="tab-btn" onclick="switchTab('personal',this)">Personal</button>
  </div>

  <div id="task-content">
    <div class="state-msg"><span class="icon">⏳</span>Loading your priorities…</div>
  </div>
</div>

</div>
<script>
const API_BASE = 'https://rzkrydqtgmuyeaipronh.supabase.co/functions/v1/brain-priorities';
const REFRESH_MS = 5 * 60 * 1000;
const MONTH_ORDER = {january:1,february:2,march:3,april:4,may:5,june:6,july:7,august:8,september:9,october:10,november:11,december:12};
const OWNER_CONFIG = {
  dave:   {label:'Dave',   initials:'D',  bg:'rgba(43,125,148,0.2)',   color:'#3a9ab5', border:'rgba(43,125,148,0.4)'},
  doreen: {label:'Doreen', initials:'Dr', bg:'rgba(196,126,176,0.15)', color:'#d49ec8', border:'rgba(196,126,176,0.35)'},
};

// Read key from URL — ?key=xxx
const KEY = new URLSearchParams(window.location.search).get('key') || '';

let currentData = null, currentTab = 'all';

function ownerCfg(o) {
  return OWNER_CONFIG[o?.toLowerCase()] || {
    label: o || 'You',
    initials: (o||'U')[0].toUpperCase(),
    bg:'rgba(255,255,255,0.08)', color:'#aaa', border:'rgba(255,255,255,0.15)'
  };
}

function init() {
  if (!KEY) {
    document.getElementById('no-key').style.display = 'block';
    return;
  }
  document.getElementById('dashboard').style.display = 'block';
  load();
  setInterval(load, REFRESH_MS);
}

async function load() {
  const btn = document.getElementById('refresh-btn');
  btn.classList.add('spinning'); btn.textContent = '↻ Loading…';
  try {
    const res = await fetch(`${API_BASE}?key=${encodeURIComponent(KEY)}`);
    if (res.status === 401) { showError('Invalid key in URL.'); return; }
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    currentData = await res.json();

    // Owner display
    const cfg = ownerCfg(currentData.owner);
    const av = document.getElementById('owner-avatar');
    av.textContent = cfg.initials;
    av.style.cssText = `background:${cfg.bg};color:${cfg.color};border:1.5px solid ${cfg.border}`;
    document.getElementById('owner-name').textContent = cfg.label;
    document.getElementById('header-sub').textContent = `${cfg.label}'s Priorities`;
    document.title = `${cfg.label}'s Priorities — Studio Strong`;

    renderStats(currentData);
    renderTasks(currentData, currentTab);
    document.getElementById('last-refresh').textContent =
      'updated ' + new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  } catch(e) {
    showError(e.message);
  } finally {
    btn.classList.remove('spinning'); btn.textContent = '↻ Refresh';
  }
}

function renderStats(data) {
  const biz = (data.business||[]).length, per = (data.personal||[]).length;
  const cur = new Date().getMonth()+1;
  const thisMonth = [...(data.business||[]),...(data.personal||[])].filter(t=>MONTH_ORDER[(t.due_month||'').toLowerCase()]===cur).length;
  document.getElementById('stats-row').innerHTML = `
    <div class="stat-chip"><strong>${biz+per}</strong>total tasks</div>
    <div class="stat-chip"><strong>${biz}</strong>business</div>
    <div class="stat-chip"><strong>${per}</strong>personal</div>
    <div class="stat-chip"><strong>${thisMonth}</strong>this month</div>`;
}

function switchTab(tab, el) {
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  currentTab = tab;
  if (currentData) renderTasks(currentData, tab);
}

function getDueNum(t) {
  const dm = (t.due_month||'').toLowerCase();
  if (MONTH_ORDER[dm]) return MONTH_ORDER[dm];
  for (const [n,v] of Object.entries(MONTH_ORDER)) if (t.content.toLowerCase().includes(n)) return v;
  return 99;
}

function renderTasks(data, tab) {
  const container = document.getElementById('task-content');
  let tasks = [];
  if (tab==='all'||tab==='business') tasks = tasks.concat((data.business||[]).map(t=>({...t,_src:'business'})));
  if (tab==='all'||tab==='personal') tasks = tasks.concat((data.personal||[]).map(t=>({...t,_src:'personal'})));

  if (!tasks.length) { container.innerHTML=`<div class="state-msg"><span class="icon">✓</span>All clear — nothing here.</div>`; return; }

  const cur = new Date().getMonth()+1;
  tasks.sort((a,b)=>{ const adj=n=>n>=cur?n:n+12; return adj(getDueNum(a))-adj(getDueNum(b)); });

  const groups = {};
  for (const t of tasks) {
    let dm = (t.due_month||'').toLowerCase();
    if (!dm) for (const n of Object.keys(MONTH_ORDER)) { if (t.content.toLowerCase().includes(n)){dm=n;break;} }
    const key = dm ? dm[0].toUpperCase()+dm.slice(1) : 'No date';
    if (!groups[key]) groups[key]=[];
    groups[key].push(t);
  }

  const ft = data.fetched_at ? new Date(data.fetched_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) : '';
  let html = `<div class="fetched-time">fetched ${ft}</div>`;

  for (const [month, items] of Object.entries(groups)) {
    const ml = month.toLowerCase();
    const pc = ['april','may','june'].includes(ml) ? `month-${ml}` : ml==='no date' ? 'month-nodate' : 'month-other';
    html += `<div class="month-group"><div class="month-label"><span class="month-pill ${pc}">${month}</span><span class="month-count">${items.length} task${items.length!==1?'s':''}</span></div>`;
    for (const t of items) {
      const src = t._src==='personal'?'<span class="tag tag-personal">personal</span>':'<span class="tag tag-business">business</span>';
      const topics = (t.topics||[]).slice(0,2).map(tp=>`<span class="tag tag-topic">${esc(tp)}</span>`).join('');
      const people = t.people?.length ? `<span class="task-people">👤 ${t.people.slice(0,3).map(esc).join(', ')}</span>` : '';
      const content = t.content.length>180 ? t.content.slice(0,180)+'…' : t.content;
      html += `<div class="task-card"><div class="task-content">${esc(content)}</div><div class="task-meta">${src}${topics}${people}</div></div>`;
    }
    html += `</div>`;
  }
  container.innerHTML = html;
}

function showError(msg) {
  document.getElementById('task-content').innerHTML =
    `<div class="error-bar">⚠ ${esc(msg)}</div><div class="state-msg"><span class="icon">🔑</span>Check your URL key.</div>`;
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

window.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
